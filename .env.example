# Keep Playing — environment template
# Copy to .env.local and fill in.

# ---------- Database ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/keep_playing
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/keep_playing

# ---------- Auth ----------
AUTH_SECRET=change-me-to-a-long-random-string
COOKIE_DOMAIN=localhost

# ---------- Storage (Cloudflare R2) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=keep-playing-dev
R2_PUBLIC_URL=

# ---------- Transcription ----------
OPENAI_API_KEY=
TRANSCRIPTION_MODEL=whisper-1
TRANSCRIPTION_MAX_MINUTES_PER_NOTE=10
TRANSCRIPTION_MAX_MINUTES_PER_USER_PER_DAY=60
TRANSCRIPTION_MONTHLY_USD_CAP=200

# ---------- WhatsApp ----------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ---------- AI (Stage 2) ----------
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-7
AI_TOKENS_PER_USER_PER_DAY=50000
AI_MONTHLY_USD_CAP=300

# ---------- Email ----------
RESEND_API_KEY=
EMAIL_FROM=hello@ahtohmoh.com

# ---------- Monitoring ----------
SENTRY_DSN=
POSTHOG_KEY=

# ---------- Background jobs ----------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---------- Real-time (Stage 2) ----------
DAILY_API_KEY=
