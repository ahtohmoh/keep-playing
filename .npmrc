auto-install-peers=true
strict-peer-dependencies=false
prefer-workspace-packages=true
link-workspace-packages=true
# React Native tooling cannot traverse pnpm's isolated symlink layout —
# Expo's monorepo guidance requires the hoisted linker. This is what made
# EAS builds fail on @babel/runtime, expo-asset, and stale autolinking.
node-linker=hoisted
