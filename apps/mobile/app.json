{
  "expo": {
    "name": "Keep Playing",
    "slug": "keep-playing",
    "owner": "krasumashi",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "keepplaying",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#060709",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/adaptive-icon.png",
      "backgroundColor": "#060709",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ahtohmoh.keepplaying"
    },
    "android": {
      "package": "com.ahtohmoh.keepplaying",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060709"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "29223b1b-efbd-431e-a185-28d02e17639a"
      }
    }
  }
}
